{
  "name": "@salve-software/rn-tui",
  "description": "Terminal UI debugger for React Native",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "yarn@4.9.1",
  "workspaces": [
    "packages/rn-tui-types"
  ],
  "bin": "./bin/rn-tui.tsx",
  "files": [
    "bin",
    "src",
    "scripts"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx bin/rn-tui.tsx",
    "start": "tsx bin/rn-tui.tsx",
    "sim": "node scripts/rn-tui-sim.mjs",
    "typecheck": "yarn build && tsc --noEmit",
    "build": "yarn workspace @salve-software/rn-tui-types build",
    "test": "yarn workspaces foreach -Apt run test"
  },
  "dependencies": {
    "@salve-software/rn-tui-types": "workspace:^",
    "figlet": "^1.11.0",
    "ink": "^7.0.6",
    "json-colorizer": "^3.0.1",
    "react": "^19.1.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.0.0",
    "typescript": "~5.8.3"
  }
}
