{
  "name": "salvetron",
  "description": "Terminal UI debugger for React Native",
  "version": "0.1.10",
  "type": "module",
  "packageManager": "yarn@4.9.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/Salve-Software/salvetron.git"
  },
  "workspaces": [
    "packages/salvetron-types"
  ],
  "bin": "./bin/salvetron.tsx",
  "files": [
    "bin",
    "src",
    "scripts",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "yarn build && tsx bin/salvetron.tsx",
    "start": "tsx bin/salvetron.tsx",
    "sim": "node scripts/salvetron-sim.mjs",
    "typecheck": "yarn build && tsc --noEmit",
    "build": "yarn workspace @salve-software/salvetron-types build",
    "test": "yarn build && tsx --test \"src/**/__tests__/*.test.ts\" && yarn workspaces foreach -Apt run test",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "@salve-software/salvetron-types": "^1.0.0",
    "figlet": "^1.11.0",
    "ink": "^7.0.6",
    "json-colorizer": "^3.0.1",
    "react": "^19.1.0",
    "tsx": "^4.0.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "~5.8.3"
  }
}
