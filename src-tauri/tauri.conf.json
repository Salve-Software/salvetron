{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mako",
  "version": "0.1.0",
  "identifier": "com.gabrielpereira.mako",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "mako",
        "width": 900,
        "height": 600,
        "minWidth": 850,
        "minHeight": 400,
        "visible": false,
        "backgroundColor": "#3b3a36",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,

        "trafficLightPosition": {
          "x": 18,
          "y": 20
        }
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "draggable-window",
          "windows": ["*"],
          "permissions": ["core:default", "core:window:allow-start-dragging"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
