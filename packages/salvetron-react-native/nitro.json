{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["salvetron"],
  "ios": {
    "iosModuleName": "NitroSalvetron"
  },
  "android": {
    "androidNamespace": ["salvetron"],
    "androidCxxLibName": "NitroSalvetron"
  },
  "autolinking": {
    "NitroSalvetron": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridSalvetron"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridSalvetron"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
