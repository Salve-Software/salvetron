{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["rntuisdk"],
  "ios": {
    "iosModuleName": "NitroRnTuiSdk"
  },
  "android": {
    "androidNamespace": ["rntuisdk"],
    "androidCxxLibName": "NitroRnTuiSdk"
  },
  "autolinking": {
    "NitroRnTuiSdk": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridRnTuiSdk"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridRnTuiSdk"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
